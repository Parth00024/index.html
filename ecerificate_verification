<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <title>Certificate Verification</title>
  <style>
    body {
      font-family: Arial, sans-serif;
      text-align: center;
      margin-top: 80px;
    }
    .valid { color: green; }
    .invalid { color: red; }
  </style>
</head>
<body>

<h2>Certificate Verification</h2>
<div id="result">Checking certificate...</div>

<script>

// 🔴 PASTE YOUR CSV LINK HERE
const CSV_URL = "PASTE_YOUR_CSV_LINK_HERE";

const params = new URLSearchParams(window.location.search);
const certId = params.get("id");

if (!certId) {
  document.getElementById("result").innerHTML =
    "<h3 class='invalid'>Invalid Request</h3>";
} else {
  fetch(CSV_URL)
    .then(response => response.text())
    .then(data => {
      const rows = data.split("\n");
      let found = false;

      for (let i = 1; i < rows.length; i++) {
        const cols = rows[i].split(",");
        if (cols[0] && cols[0].trim() === certId.trim()) {
          found = true;
          document.getElementById("result").innerHTML =
            "<h3 class='valid'>✅ Certificate Verified</h3>" +
            "<p><strong>Name:</strong> " + cols[1] + "</p>" +
            "<p><strong>Certificate ID:</strong> " + certId + "</p>";
          break;
        }
      }

      if (!found) {
        document.getElementById("result").innerHTML =
          "<h3 class='invalid'>❌ Invalid Certificate</h3>";
      }
    });
}

</script>

</body>
</html>
